{
  "permissions": {
    "deny": [
      "Edit(/CLAUDE.md)",
      "Write(/CLAUDE.md)",
      "Edit(/.claude/settings.json)",
      "Write(/.claude/settings.json)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-session-snapshot.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-wikilinks.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
